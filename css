/* =========================================
   ABOUT PAGE SPECIFIC STYLES
   ========================================= */

/* Hero Section with Fade Effect */
.about-page .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    /* Fades from brand Cream (#FDF5E6) to transparent to reveal the image */
    background: linear-gradient(to right, 
                #FDF5E6 35%, 
                rgba(253, 245, 230, 0.8) 55%, 
                transparent 100%), 
                url('../images/about%20background%20picture.png');
    background-size: cover;
    background-position: right center;
    background-repeat: no-repeat;
    padding: 0 8%;
}

.about-page .hero-text {
    max-width: 550px;
    text-align: left; /* Text stays on the left solid-colored side */
}

.about-page h2 {
    font-size: 4.5rem;
    margin: 0;
}

.about-page .divider {
    color: #B55D3A;
    font-size: 1.8rem;
    margin: 10px 0;
}

.about-page .tagline {
    font-weight: bold;
    margin-bottom: 25px;
}

.about-page h3 {
    color: #B55D3A;
    margin-top: 20px;
}

.about-page p {
    line-height: 1.6;
    margin-bottom: 15px;
}

/* Values layout using Flexbox */
.about-page .values-grid {
    display: flex;
    gap: 30px;
    margin-top: 35px;
}

.about-page .value-item h4 {
    margin: 0 0 5px 0;
    font-size: 1rem;
}

.about-page .value-item p {
    font-size: 0.85rem;
    line-height: 1.4;
}

footer {
    text-align: center;
    padding: 20px;
    background-color: #FDF5E6;
    border-top: 1px solid #3E2723;
}
/* =========================================
   PRODUCTS PAGE STYLES
   ========================================= */

/* 1. Background & Layout */
body.products-page {
    /* FIX: Added ../ to go out of 'css' folder and into 'images' folder */
    background-image: linear-gradient(rgba(253, 245, 230, 0.8), rgba(253, 245, 230, 0.8)), 
                      url('../images/product%20background%20picture.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    color: #3e2723;
    text-align: center;
    min-height: 100vh;
}

/* 2. Header & Navigation */
.products-page header {
    background-color: rgba(253, 245, 230, 0.95); 
    border-bottom: 2px solid #8d6e63;
    padding: 15px 5%;
    display: flex;
    justify-content: space-between; 
    align-items: center;
}

.products-page header h1 {
    margin: 0;
    font-size: 1.8rem;
    font-family: 'Georgia', serif;
}

.products-page nav ul {
    padding: 0;
    list-style-type: none;
    margin: 0;
    display: flex; 
}

.products-page nav ul li {
    margin-left: 25px;
}

.products-page nav a {
    text-decoration: none;
    color: #3E2723;
    font-weight: bold;
}

.products-page nav a:hover {
    color: #B55D3A;
}

/* 3. Product Grid */
.products-page main {
    padding: 40px 20px;
}

.products-page .product-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px;
    margin-top: 30px;
}

.products-page .product-card {
    background-color: rgba(255, 255, 255, 0.9);
    border: 1px solid #8d6e63;
    border-radius: 12px;
    width: 220px;
    padding: 15px;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
}

.products-page .product-card:hover {
    transform: translateY(-10px);
}

.products-page .product-card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 15px;
}

.products-page .product-name {
    display: block;
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 5px;
    font-family: 'Georgia', serif;
}

.products-page .product-price {
    color: #B55D3A;
    font-weight: bold;
    font-size: 1.1rem;
}

.products-page footer {
    padding: 20px;
    background-color: rgba(253, 245, 230, 0.95);
    border-top: 1px solid #8d6e63;
    margin-top: auto;
}
/* ==========================================================================
   ENQUIRY FORM COMPONENT BLOCKS
   ========================================================================== */
.bg-cream-page {
    background-color: #FDF5E6 !important; /* Forces your brand cream backdrop */
}

form {
    background-color: #EDE8D0; /* Filled tint box matching wireframes exactly */
    padding: 30px;
    border: 2px solid #C4BEA5;
    border-radius: 8px;
    width: 100%;
    max-width: 400px;
    margin: 20px auto 0 auto;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06);
}

form label {
    display: block;
    margin-top: 15px;
    font-size: 0.95rem;
    text-align: left;
    font-weight: bold;
    color: #3E2723;
}

form input, 
form select, 
form textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    border: 1px solid #A6A085;
    border-radius: 4px;
    background-color: #FFFFFF; /* High contrast inner inputs */
    color: #3E2723;
    font-family: Arial, sans-serif;
}

form button {
    background-color: #8D6E63; /* Earthy brown button accent color */
    color: #FFFFFF; /* Bold white typography contrast */
    padding: 12px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    margin-top: 25px;
    font-size: 1rem;
    width: 100%;
    transition: background-color 0.2s ease;
}

form button:hover {
    background-color: #3E2723; /* Swaps cleanly to your primary dark brown */
}
h1, h2, h3 {
    font-family: 'Georgia', serif; /* Heading font */
    margin: 0;
}

nav ul {
    padding: 0;
    list-style-type: none;
    margin: 0;
    display: flex; 
}

nav ul li {
    margin-left: 25px;
}

nav a {
    text-decoration: none;
    color: #3E2723;
    font-weight: bold;
    transition: 0.3s;
}

nav a:hover {
    color: #B55D3A; /* Brand accent color */
}

/* 3. CONTENT BOX STYLING */
main {
    flex: 1; 
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.content-box {
    background-color: rgba(255, 255, 255, 0.9);
    padding: 30px;
    width: 90%;
    max-width: 650px;
    border-radius: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    border: 1px solid #3E2723;
    box-sizing: border-box;
}

/* 4. IMAGES */
.hero-image {
    display: block;
    margin: 20px auto;
    border: 3px solid #3E2723;
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 8px;
}

/* 5. FOOTER */
footer {
    background-color: rgba(253, 245, 230, 0.95);
    padding: 20px 10px;
    border-top: 2px solid #3E2723;
    width: 100%;
    box-sizing: border-box;
}

/* 6. MOBILE OPTIMIZATION */
@media (max-width: 480px) {
    header {
        flex-direction: column;
        text-align: center;
    }
    nav ul {
        margin-top: 15px;
    }
    nav ul li {
        margin: 5px 10px;
    }
}
#formResponse p {
    margin-top: 20px;
    padding: 12px;
    border-radius: 6px;
    font-weight: bold;
    text-align: center;
}

.success-box p {
    background-color: #E2ECE9;
    color: #2E5A44;
    border: 1px solid #A3C1AD;
}
