/* --- LIGHTBOX MODAL CORE ENGINE LAYOUT --- */
.lightbox {
    display: none;       /* Hidden by default until JavaScript flips it to flex */
    position: fixed !important;
    z-index: 99999 !important; /* Floats safely over absolutely everything */
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(62, 39, 35, 0.95) !important; /* Dark chocolate tint overlay */
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
}

/* Lightbox pop-up window styling card box */
.lightbox-content-box {
    background-color: #FDF5E6 !important; /* Clean soft background cream */
    max-width: 550px;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}

.lightbox-content-box img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
}

#lightboxCaption {
    padding: 20px;
    margin: 0;
    color: #3E2723;
    font-weight: bold;
    font-size: 1.05rem;
    line-height: 1.4;
}

/* X Close Button layout links setup */
.lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: #FDF5E6;
    font-size: 45px;
    font-weight: bold;
    cursor: pointer;
    user-select: none;
}

.lightbox-close:hover {
    color: #B55D3A;
}
