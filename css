/* 1. GLOBAL STYLES & TYPOGRAPHY */
body {
    margin: 0;
    padding: 0;
    font-family: 'Arial', 'Aptos', sans-serif; /* Body font */
    background-color: #FDF5E6; /* Cream background for ALL pages */
    color: #3E2723; /* Brown text for ALL pages */
    text-align: center;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Specific Background Logic for Home Page ONLY */
body.home-page {
    background-image: url('../images/background picture.png'); /* */
    background-size: cover; /* */
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
}

/* 2. HEADER & NAVIGATION (Flexbox Layout) */
header {
    background-color: rgba(253, 245, 230, 0.95); 
    border-bottom: 2px solid #3E2723;
    padding: 15px 5%;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between; 
    align-items: center;
}
    /* =========================================
   GLOBAL STYLES (Applies to all pages)
   ========================================= */
body {
