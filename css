}

h1, h2, h3 {
    font-family: 'Georgia', serif; /* Header font */
}

header {
    background-color: #FDF5E6;
    border-bottom: 1px solid #3E2723;
    padding: 20px 5%;
    
    /* ADD THESE THREE LINES to split the title and nav bar */
    display: flex;
    justify-content: space-between;
    align-items: center;
}

nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    
